# Anthropic API key for Claude Code SDK
ANTHROPIC_API_KEY=

# Slack Bot OAuth Token (xoxb-...) — same as main app's SLACK_APP_TOKEN
SLACK_APP_TOKEN=

# Slack Bot Token for Bolt (xoxb-...) — for posting messages, same value as SLACK_APP_TOKEN
SLACK_BOT_TOKEN=

# Slack App-Level Token (xapp-...) — for Socket Mode connection
SLACK_SOCKET_TOKEN=

# Supabase project URL — same as main app's NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role key (bypasses RLS) — same as main app
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM encryption key (base64-encoded, 32 bytes) — same as main app
TOKEN_ENCRYPTION_KEY=

# Switchboard MCP endpoint URL
SWITCHBOARD_MCP_URL=https://www.get-switchboard.com/api/mcp/http
